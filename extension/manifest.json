{
  "manifest_version": 3,
  "name": "ScopeNest",
  "version": "1.0.4",
  "minimum_chrome_version": "116",
  "description": "Isolated browser contexts for testing, research, and development.",
  "key": "",
  "permissions": ["activeTab", "nativeMessaging", "storage", "sidePanel"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "ScopeNest",
    "default_popup": "src/ui/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "src/ui/index.html"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
